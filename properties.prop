#--------------------------File Converter Association---------------------------
#%i č il placeholder del nome del file di ingresso (con path completo)
#%o č il placeholder del nome del file di uscita (con path completo)
#%td č il placeholder di una eventuale dir temporanea dove il comando ripone eventuali file di interelaborazione (con path completo).
#Ovviamente la posizione e la presenza/assenza dei placeholder su elencati dipende dalla forma della linea di comando.
 
#pdf=/usr/bin/pdftotext %i %o
pdf=/bin/bash /home/lsola/documat/DeploymentServerSide/pdfconversion /home/lsola/documatTempdir %td %i %o
ps=/usr/bin/ps2ascii %i  %o
doc=catdoc %i
rtf=catdoc %i
txt=cp %i %o
html=html2text -nobs -o %o %i
png=gocr -a 85 -i %i -o %o
gif=gocr -i %i -o %o
jpg=gocr -i %i -o %o
jpeg=gocr -i %i -o %o